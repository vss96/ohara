/target
**/*.rs.bk
.DS_Store

# Git worktrees for parallel branch work
/.worktrees/

# Build artifacts under fixtures (the repos themselves are scripted, not committed)
/fixtures/*/repo
fixtures/medium/repo/

# Local index data
.ohara/

# fastembed model cache (created by live tests, large binary blobs)
**/.fastembed_cache/

# Perf-benchmark fixtures (shallow-cloned on demand by tests/perf/fetch_questdb.sh).
# `/target` already covers the default location (target/perf-fixtures/), but
# this catches the case where someone fetches into a non-default path.
**/perf-fixtures/

# Ruflo runtime (regenerated by `claude-flow init`); ignore until you decide whether to commit ruflo config
.claude-flow/data/
.claude-flow/logs/
.claude-flow/sessions/

# Per-developer Claude Code state (settings, sessions, and ruflo MCP scaffolding)
.claude/
.mcp.json
# Exception: the Claude Code plugin's MCP entry must ship — it registers the
# ohara stdio server when users install the plugin from the marketplace.
!plugins/ohara/.mcp.json
CLAUDE.md
/docs-book/book
